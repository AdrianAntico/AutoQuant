\name{aq_decision_optionality}
\alias{aq_decision_optionality}
\title{Create Decision Optionality Records}
\usage{
aq_decision_optionality(optionality)
}
\arguments{
\item{optionality}{Data frame or list of optionality records.}
}
\value{
A data.table of typed optionality records.
}
\description{
Creates canonical optionality records describing future choices created,
preserved, constrained, or foreclosed by an alternative.
}
