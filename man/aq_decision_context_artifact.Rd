\name{aq_decision_context_artifact}
\alias{aq_decision_context_artifact}
\title{Create a Decision Context Artifact}
\usage{
aq_decision_context_artifact(decision_context, artifact_id = NULL)
}
\arguments{
\item{decision_context}{An \code{aq_decision_context} object.}
\item{artifact_id}{Optional artifact id.}
}
\value{
A canonical decision-context artifact.
}
\description{
Creates a canonical table artifact containing alternative assessment evidence
and decision-management metadata.
}
