\name{aq_assess_decision_optionality}
\alias{aq_assess_decision_optionality}
\title{Assess Decision Optionality}
\usage{
aq_assess_decision_optionality(decision_context)
}
\arguments{
\item{decision_context}{An \code{aq_decision_context} object.}
}
\value{
A data.table of optionality assessments.
}
\description{
Categorizes optionality evidence for each alternative without executing or
optimizing any decision.
}
