\name{aq_decision_alternative}
\alias{aq_decision_alternative}
\title{Create Decision Alternatives}
\usage{
aq_decision_alternative(alternatives)
}
\arguments{
\item{alternatives}{Data frame or list of alternative records.}
}
\value{
A data.table of typed decision alternatives.
}
\description{
Creates canonical decision alternative records for use inside a decision context.
}
